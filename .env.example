# Copy to .env for local development: cp .env.example .env
# In production (Railway) these are set as service variables.

# --- PostgreSQL (main warehouse) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=wiki
POSTGRES_PASSWORD=wiki
POSTGRES_DB=wiki
# Read-only user for the dashboard (created by migrations)
POSTGRES_RO_USER=wiki_ro
POSTGRES_RO_PASSWORD=wiki_ro

# --- Kafka ---
# Inside docker network services use kafka:9092; from the host use localhost:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC_EVENTS=wiki.recentchange
KAFKA_TOPIC_DLQ=wiki.recentchange.dlq
KAFKA_CONSUMER_GROUP=pg-writer

# --- Redis (dedup + live counters) ---
REDIS_URL=redis://localhost:6379/0

# --- Wikimedia EventStreams (producer) ---
SSE_URL=https://stream.wikimedia.org/v2/stream/recentchange
# Wikimedia asks for a descriptive User-Agent with contact info
SSE_USER_AGENT=wiki-stream-analytics/0.1 (https://github.com/TikshiKE/wiki-stream-analytics; evgeny.kren.engineer@gmail.com)

# --- Telegram alerts (Airflow callbacks + healthchecker; empty = alerts disabled) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Maintenance (Airflow) ---
# Raw partitions older than this are dropped by the daily maintenance DAG
RETENTION_DAYS=7

# --- Airflow (local web UI http://localhost:8080) ---
AIRFLOW_FERNET_KEY=JkYb-hzyrIph-CdbTYMQRr9wlHOKZlkZhq_fEL5L2Io=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# --- Dashboard (Streamlit http://localhost:8501) ---
GITHUB_REPO_URL=https://github.com/TikshiKE/wiki-stream-analytics

# --- Healthchecker (http://localhost:8090/health) ---
DASHBOARD_URL=http://localhost:8501
HEALTH_PORT=8090
DB_SIZE_WARN_BYTES=10737418240
ALERT_THROTTLE_SECONDS=1800
KAFKA_LAG_WARN=10000
KAFKA_LAG_CRITICAL=50000
FRESHNESS_WARN_MINUTES=5
FRESHNESS_CRITICAL_MINUTES=15

# --- dbt (Airflow dbt_hourly DAG) ---
# dev = local Postgres, prod = Railway Postgres
DBT_TARGET=dev
